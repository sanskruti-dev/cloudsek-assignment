# Application
APP_NAME=http-metadata-inventory
APP_ENV=development
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# MongoDB
MONGO_URI=mongodb://mongo:27017
MONGO_DB=metadata_inventory
MONGO_COLLECTION=url_metadata
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_STARTUP_RETRY_ATTEMPTS=30
MONGO_STARTUP_RETRY_DELAY_S=2.0

# HTTP fetcher
FETCH_TIMEOUT_S=15.0
FETCH_MAX_REDIRECTS=5
FETCH_MAX_BYTES=5242880  # 5 MiB
FETCH_USER_AGENT=HTTPMetadataInventory/1.0 (+https://example.com/bot)

# Security
# Block private/loopback/link-local addresses to mitigate SSRF.
# Only disable in trusted/test environments.
BLOCK_PRIVATE_NETWORKS=true
ALLOWED_SCHEMES=http,https
